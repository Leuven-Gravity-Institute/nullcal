{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "language": "en",
    "dictionaries": [
        "en",
        "ignore-words"
    ],
    "dictionaryDefinitions": [
        {
            "name": "ignore-words",
            "path": ".ignore_words.txt",
            "addWords": true
        }
    ],
    "languageSettings": [
        {
            "languageId": "*",
            "locale": "en",
            "dictionaries": [
                "en",
                "ignore-words"
            ]
        }
    ],
    "ignorePaths": [
        ".github/*",
        "pyproject.toml",
        "docs/conf.py",
        "docs/requirements.txt",
        ".pypirc",
    ],
    "ignoreRegExpList": [
        "np(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)+"
    ],
}
