{
    "version": "0.2",
    "language": "en",
    "ignorePaths": [
        ".github/*",
        "pyproject.toml",
        "docs/conf.py",
        "docs/requirements.txt",
        ".pypirc",
    ],
    "ignoreRegExpList": [
        "np(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)+"
    ],
    "words": [
        "stft",
        "nullcal",
        "bilby",
        "gaussianity",
        "kstest",
        "rtol",
        "kstest",
        "pvalue",
        "geocent",
        "recalib",
        "XPHM",
    ]
}
